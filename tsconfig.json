{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM"],
    "strictNullChecks": true,
    "strictFunctionTypes": true,
    "skipLibCheck": true,
    "noEmit": true,
    "paths": {
      "src/*": ["./src/*"],
      "@client/*": ["./foundry/resources/app/client/*"],
      "@common/*": ["./foundry/resources/app/common/*"]
    }
  },
  "include": [
    "src/**/*.ts",
    "foundry/resources/app/client/*",
    "foundry/resources/app/common/*"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "./src/tools"
  ]
}